{
  "dashboard": {
    "title": "Cadencia — System Overview",
    "uid": "cadencia-system",
    "tags": ["cadencia", "production"],
    "timezone": "Asia/Kolkata",
    "refresh": "30s",
    "panels": [
      {
        "id": 1, "title": "Request Rate (rpm)", "type": "timeseries",
        "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
        "targets": [{"expr": "rate(http_requests_total[1m]) * 60"}]
      },
      {
        "id": 2, "title": "Error Rate (5xx %)", "type": "gauge",
        "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
        "targets": [{"expr": "rate(http_responses_total{status=~'5..'}[5m]) / rate(http_responses_total[5m]) * 100"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 5, "color": "red"}]}}}
      },
      {
        "id": 3, "title": "Latency p50 / p95 / p99", "type": "timeseries",
        "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
          {"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
          {"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
        ]
      },
      {
        "id": 4, "title": "Active SSE Connections", "type": "stat",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
        "targets": [{"expr": "cadencia_active_sse_connections"}]
      },
      {
        "id": 5, "title": "Circuit Breaker States", "type": "table",
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
        "targets": [{"expr": "cadencia_circuit_breaker_state"}]
      },
      {
        "id": 6, "title": "ECS Tasks (desired vs running)", "type": "timeseries",
        "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6},
        "targets": [
          {"expr": "aws_ecs_desired_count", "legendFormat": "desired"},
          {"expr": "aws_ecs_running_count", "legendFormat": "running"}
        ]
      },
      {
        "id": 7, "title": "ALB Healthy Hosts", "type": "stat",
        "gridPos": {"x": 18, "y": 8, "w": 6, "h": 6},
        "targets": [{"expr": "aws_alb_healthy_host_count"}]
      }
    ]
  }
}

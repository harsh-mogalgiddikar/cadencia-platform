# ════════════════════════════════════════════════════════════════════════════
# Cadencia — Environment Variables Reference
# context.md §17: All configuration via environment variables. NEVER hardcode.
#
# Usage:
#   cp .env.example .env
#   Fill in all REQUIRED values marked below before running.
#
# SECURITY: .env is in .gitignore. NEVER commit real secrets.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
APP_VERSION=0.1.0

# ── Database (PostgreSQL 16 + pgvector) ─────────────────────────────────────
# REQUIRED — Must include ssl=require in production
DATABASE_URL=postgresql+asyncpg://cadencia:cadencia_dev@localhost:5432/cadencia
POSTGRES_USER=cadencia
POSTGRES_PASSWORD=cadencia_dev
POSTGRES_DB=cadencia

# ── Cache (Redis 7) ─────────────────────────────────────────────────────────
# REQUIRED
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ───────────────────────────────────────────────────────
# REQUIRED — context.md §14: RS256-signed JWT. HS256 is PROHIBITED.
# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=REPLACE_WITH_RS256_PRIVATE_KEY_PEM
JWT_PUBLIC_KEY=REPLACE_WITH_RS256_PUBLIC_KEY_PEM
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Algorand ─────────────────────────────────────────────────────────────────
# REQUIRED
ALGORAND_NETWORK=localnet
ALGORAND_ALGOD_ADDRESS=http://localhost:4001
ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_KMD_ADDRESS=http://localhost:4002
ALGORAND_KMD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# REQUIRED — context.md §14: NEVER commit mnemonic to VCS
# 25-word Algorand account mnemonic for escrow contract creator
ALGORAND_ESCROW_CREATOR_MNEMONIC=REPLACE_WITH_25_WORD_MNEMONIC

# ── Escrow / Blockchain Safety ───────────────────────────────────────────────
# context.md §12 SRS-SC-001: Dry-run MUST be true in non-production
ESCROW_DRY_RUN_ENABLED=true

# context.md §14: MUST be false in production. SIM- tokens rejected everywhere.
X402_SIMULATION_MODE=false

# ── LLM Provider ────────────────────────────────────────────────────────────
# Pluggable via IAgentDriver adapter (context.md §13)
LLM_PROVIDER=google
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ── CORS ─────────────────────────────────────────────────────────────────────
# context.md §14: Wildcard * is PROHIBITED in production.
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Compliance & Data Residency ──────────────────────────────────────────────
# context.md §11: minimum 7-year audit log retention
AUDIT_RETENTION_YEARS=7
# context.md §14: ALL production data MUST reside in ap-south-1
DATA_RESIDENCY_REGION=ap-south-1

# ── Rate Limiting ────────────────────────────────────────────────────────────
# context.md §15: 100 req/60s per enterprise; 50 LLM req/min
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW_SECONDS=60
LLM_RATE_LIMIT_REQUESTS=50
LLM_RATE_LIMIT_WINDOW_SECONDS=60

# ── Anchor Service ───────────────────────────────────────────────────────────
# Enables Merkle root anchoring on-chain after escrow release
ANCHOR_SERVICE_ENABLED=true

# ── Webhook Notifier (Phase 3) ──────────────────────────────────────────────
# HMAC-SHA256 signed outbound webhooks for settlement events.
# Optional — if WEBHOOK_DELIVERY_URL is empty, webhooks are silently skipped.
WEBHOOK_DELIVERY_URL=
WEBHOOK_SIGNING_SECRET=REPLACE_WITH_HMAC_SECRET
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# ── x402 Payment (Phase 3) ──────────────────────────────────────────────────
# HMAC secret for verifying X-Payment-Proof headers.
# Optional — if empty, signature verification is skipped.
X402_PAYMENT_SECRET=REPLACE_WITH_PAYMENT_HMAC_SECRET

# ── LLM Agent Driver (Phase 4) ──────────────────────────────────────────────
# LLM_PROVIDER: "openai" | "gemini" | "stub" (default: "stub")
# Default: "stub" — safe for development and testing.
LLM_PROVIDER=stub

# Required only when LLM_PROVIDER=openai:
OPENAI_API_KEY=
# Required only when LLM_PROVIDER=gemini:
GEMINI_API_KEY=

# Model selection (default depends on provider):
#   OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
#   Gemini: gemini-1.5-pro, gemini-1.5-flash
LLM_MODEL=gpt-4o

# Tuning parameters (safe defaults provided):
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

# ── KYC Provider ────────────────────────────────────────────────────────────
# KYC_PROVIDER: "mock" (default) | "digilocker" | "karza"
# Production: set KYC_PROVIDER=digilocker and provide API key.
KYC_PROVIDER=mock
KYC_PROVIDER_API_KEY=

# ── On-Ramp Provider ────────────────────────────────────────────────────────
# ONRAMP_PROVIDER: "mock" (default) | "moonpay" | "transak" | "wyre"
# Production: set ONRAMP_PROVIDER=moonpay and provide API key.
ONRAMP_PROVIDER=mock
ONRAMP_API_KEY=

# ── S3 Tenant Vault (Agent Memory) ──────────────────────────────────────────
# Tenant-isolated S3 storage for enterprise documents.
# Local dev: use MinIO (docker-compose includes minio service)
# Production: AWS S3 ap-south-1 with IAM roles
AWS_S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_MEMORY_CHUNK_SIZE=512
S3_MEMORY_RETENTION_DAYS=7
